{
  "manifest_version": 3,
  "name": "AdBlock ML",
  "version": "0.1.0",
  "description": "uBO-compatible blocking + AdFlush ML classifier for requests lists miss",
  "permissions": [
    "declarativeNetRequest",
    "declarativeNetRequestFeedback",
    "declarativeNetRequestWithHostAccess",
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "run_at": "document_start",
      "all_frames": false,
      "matches": ["<all_urls>"],
      "js": ["src/content/cosmetic-filter.js"]
    },
    {
      "run_at": "document_start",
      "all_frames": false,
      "matches": ["<all_urls>"],
      "js": [
        "src/content/ablation-bridge.js",
        "src/content/cosmetic.js"
      ]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AdBlock ML"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "path": "rules/easylist_5k.json",
        "id": "easylist_5k",
        "enabled": true
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["src/ml/model.onnx", "vendor/ort.min.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
